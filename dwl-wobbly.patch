+void
+wobblybegin(Client *c)
+{
+	if (!wobbly_windows || !c || c->isfullscreen || client_is_unmanaged(c))
+		return;
+
+	wobbly.client = c;
+	wobbly.target = c->geom;
+	wobbly.x = c->geom.x;
+	wobbly.y = c->geom.y;
+	wobbly.width = c->geom.width;
+	wobbly.height = c->geom.height;
+	wobbly.vx = wobbly.vy = wobbly.vwidth = wobbly.vheight = 0;
+	wobbly.active = 1;
+	wobbly.settling = 0;
+	wl_event_source_timer_update(wobblytimer, wobbly_frame_ms);
+}
+
+void
+wobblyrelease(Client *c)
+{
+	if (!wobbly_windows || wobbly.client != c || !wobbly.active)
+		return;
+
+	wobbly.settling = 1;
+	wl_event_source_timer_update(wobblytimer, wobbly_frame_ms);
+}
+
+void
+wobblystop(Client *c)
+{
+	if (wobbly.client != c)
+		return;
+
+	wobbly.active = 0;
+	wobbly.settling = 0;
+	wobbly.client = NULL;
+	wl_event_source_timer_update(wobblytimer, 0);
+}
+
+int
+wobblytick(void *data)
+{
+	Client *c = wobbly.client;
+	struct wlr_box visual;
+	double dx, dy, dw, dh, max;
+
+	if (!wobbly.active || !c || !c->mon || !client_surface(c)->mapped) {
+		wobblystop(c);
+		return 0;
+	}
+
+	dx = wobbly.target.x - wobbly.x;
+	dy = wobbly.target.y - wobbly.y;
+	dw = wobbly.target.width - wobbly.width;
+	dh = wobbly.target.height - wobbly.height;
+	max = (double)wobbly_max_displacement;
+
+	wobbly.vx = (wobbly.vx + dx * wobbly_stiffness) * wobbly_damping;
+	wobbly.vy = (wobbly.vy + dy * wobbly_stiffness) * wobbly_damping;
+	wobbly.vwidth = (wobbly.vwidth + dw * wobbly_stiffness) * wobbly_damping;
+	wobbly.vheight = (wobbly.vheight + dh * wobbly_stiffness) * wobbly_damping;
+
+	wobbly.x += wobbly.vx;
+	wobbly.y += wobbly.vy;
+	wobbly.width += wobbly.vwidth;
+	wobbly.height += wobbly.vheight;
+
+	wobbly.x = MAX(wobbly.target.x - max, MIN(wobbly.target.x + max, wobbly.x));
+	wobbly.y = MAX(wobbly.target.y - max, MIN(wobbly.target.y + max, wobbly.y));
+	wobbly.width = MAX(wobbly.target.width - max, MIN(wobbly.target.width + max, wobbly.width));
+	wobbly.height = MAX(wobbly.target.height - max, MIN(wobbly.target.height + max, wobbly.height));
+
+	if (wobbly.settling
+			&& fabs(dx) < 0.5 && fabs(dy) < 0.5 && fabs(dw) < 0.5 && fabs(dh) < 0.5
+			&& fabs(wobbly.vx) < 0.5 && fabs(wobbly.vy) < 0.5
+			&& fabs(wobbly.vwidth) < 0.5 && fabs(wobbly.vheight) < 0.5) {
+		resizeapply(c, wobbly.target);
+		wobblystop(c);
+		return 0;
+	}
+
+	visual = (struct wlr_box){
+		.x = (int)round(wobbly.x),
+		.y = (int)round(wobbly.y),
+		.width = MAX(1 + 2 * (int)c->bw, (int)round(wobbly.width)),
+		.height = MAX(1 + 2 * (int)c->bw, (int)round(wobbly.height)),
+	};
+	resizeapply(c, visual);
+	if (c->mon)
+		wlr_output_schedule_frame(c->mon->wlr_output);
+	wl_event_source_timer_update(wobblytimer, wobbly_frame_ms);
+	return 0;
+}

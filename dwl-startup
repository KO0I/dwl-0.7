#!/bin/sh

export PKG_CONFIG_PATH="/usr/local/lib/pkgconfig:$PKG_CONFIG_PATH"
export AMD_DEBUG=nodcc,nohyperz
export MESA_SHADER_CACHE_DISABLE=1
export VST_PATH="/home/amber/proj/music_projects/VSTPlugins/VstPlugins"
export _JAVA_AWT_WM_NONREPARENTING=1
export DWL_HELPER_DIR=${DWL_HELPER_DIR:-/usr/lib/dwl-personal}
export PATH="$DWL_HELPER_DIR:$PATH"
export GTK_THEME=Wallust-Dark
export QT_STYLE_OVERRIDE=kvantum
export QT_QPA_PLATFORM='wayland;xcb'

wallpaper=$("$DWL_HELPER_DIR/dwl-wallpaper" 2>/dev/null || true)
if [ -n "$wallpaper" ]; then
	wallust run -q -s -w "$wallpaper" >/dev/null 2>&1 || true
	"$DWL_HELPER_DIR/dwl-apply-toolkit-theme" >/dev/null 2>&1 || true
	pkill -u "$(id -u)" -x swaybg 2>/dev/null || true
	swaybg -i "$wallpaper" -m fill &
fi

if command -v dwlb >/dev/null 2>&1; then
	(
		while :; do
			"$DWL_HELPER_DIR/dwlb-status"
			sleep 30
		done
	) &
	exec "$DWL_HELPER_DIR/dwlb-launch"
fi

exec <&-
exit 0

+static void
+nametag(const Arg *arg)
+{
+	char tagarg[128], *p = tagarg;
+	size_t left = sizeof tagarg;
+	int i, written;
+	uint32_t tagmask;
+	const char *cmd[] = { "dwl-nametag", tagarg, NULL };
+	Arg spawnarg = { .v = cmd };
+
+	if (!selmon)
+		return;
+
+	tagmask = selmon->tagset[selmon->seltags] & TAGMASK;
+	for (i = 0; i < TAGCOUNT; i++) {
+		if (!(tagmask & (1 << i)))
+			continue;
+		written = snprintf(p, left, "%s%d", p == tagarg ? "" : " ", i + 1);
+		if (written < 0 || (size_t)written >= left)
+			break;
+		p += written;
+		left -= written;
+	}
+	if (p != tagarg)
+		spawn(&spawnarg);
+}

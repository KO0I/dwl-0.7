+static void
+applycolors(void)
+{
+	Client *c, *focused;
+	const float *color;
+	int i;
+
+	if (root_bg)
+		wlr_scene_rect_set_color(root_bg, rootcolor);
+
+	wl_list_for_each(c, &clients, link) {
+		if (client_is_unmanaged(c))
+			continue;
+		focused = c->mon ? focustop(c->mon) : NULL;
+		color = c->isurgent ? urgentcolor : (c == focused ? focuscolor : bordercolor);
+		for (i = 0; i < 4; i++) {
+			if (c->border[i])
+				wlr_scene_rect_set_color(c->border[i], color);
+		}
+	}
+}
+
+static char *
+expandthemefile(char *buf, size_t len)
+{
+	const char *home;
+
+	if (themefile[0] != '~' || themefile[1] != '/')
+		return (char *)themefile;
+	if (!(home = getenv("HOME")))
+		return (char *)themefile;
+
+	snprintf(buf, len, "%s/%s", home, themefile + 2);
+	return buf;
+}
+
+static int
+parsecolor(const char *value, float color[4])
+{
+	unsigned int r, g, b;
+
+	while (*value == ' ' || *value == '\t')
+		value++;
+	if (*value == '#')
+		value++;
+	if (sscanf(value, "%2x%2x%2x", &r, &g, &b) != 3)
+		return 0;
+
+	color[0] = r / 255.0f;
+	color[1] = g / 255.0f;
+	color[2] = b / 255.0f;
+	color[3] = 1.0f;
+	return 1;
+}
+
+static void
+loadthemecolor(FILE *fp, const char *resource, float color[4])
+{
+	char line[256], *value;
+	size_t len = strlen(resource);
+
+	rewind(fp);
+	while (fgets(line, sizeof line, fp)) {
+		if (strncmp(line, resource, len) || line[len] != ':')
+			continue;
+		value = line + len + 1;
+		if (!parsecolor(value, color))
+			wlr_log(WLR_ERROR, "invalid color for %s in %s", resource, themefile);
+		return;
+	}
+}
+
+static void
+reloadcolors(void)
+{
+	FILE *fp;
+	char path[4096];
+
+	fp = fopen(expandthemefile(path, sizeof path), "r");
+	if (!fp) {
+		wlr_log(WLR_ERROR, "could not open theme file %s", themefile);
+		return;
+	}
+
+	loadthemecolor(fp, "dwm.normbgcolor", rootcolor);
+	loadthemecolor(fp, "dwm.normbordercolor", bordercolor);
+	loadthemecolor(fp, "dwm.selbordercolor", focuscolor);
+	loadthemecolor(fp, "dwm.urgbordercolor", urgentcolor);
+	fclose(fp);
+
+	applycolors();
+	wlr_log(WLR_INFO, "reloaded colors from %s", themefile);
+}
+
+static int
+reloadcolorssignal(int signal_number, void *data)
+{
+	reloadcolors();
+	return 0;
+}
